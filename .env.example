# Core secrets
SECRET_KEY=replace-with-a-long-random-secret


# Backend runtime
ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Data stores
POSTGRES_DB=nifty_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nifty_dashboard
REDIS_URL=redis://redis:6379/0

# Dhan option chain (required for live data)
DHAN_CLIENT_ID=replace-with-your-dhan-client-id
DHAN_ACCESS_TOKEN=replace-with-your-dhan-access-token
DHAN_BASE_URL=https://api.dhan.co
DHAN_OPTION_CHAIN_PATH=/v2/optionchain
DHAN_SYMBOL=NIFTY
# Optional: pin a specific expiry (YYYY-MM-DD). If omitted, the backend picks the nearest active expiry.
# DHAN_EXPIRY=2026-04-30

# FYERS option chain (alternative provider)
# FYERS_CLIENT_ID=YOUR_APP_ID-100
# FYERS_SECRET_KEY=YOUR_SECRET_KEY
# FYERS_REDIRECT_URI=http://localhost:5173/fyers-callback
# FYERS_ACCESS_TOKEN=   # optional; can be stored via /api/v1/fyers/callback
# FYERS_SYMBOL=NSE:NIFTY50-INDEX
# FYERS_STRIKECOUNT=12

# Legacy INDstocks settings (currently unused by backend)
INDSTOCKS_BASE_URL=https://api.indstocks.com
INDSTOCKS_QUOTE_PATH=/market/quotes/full
INDSTOCKS_SYMBOL=NIFTY
OPTION_CHAIN_CACHE_TTL_SECONDS=10
OPTION_CHAIN_REFRESH_SECONDS=15
OPTION_CHAIN_PROVIDER=dhan

# Google OAuth
# Set this to the frontend callback route registered in Google Cloud Console.
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:5173/oauth-callback

# Frontend build-time env
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_WS_BASE_URL=ws://127.0.0.1:8000
VITE_APP_NAME=Nifty 50 Live Option Chain Dashboard
